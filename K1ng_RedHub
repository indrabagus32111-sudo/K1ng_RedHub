MakeSection(playerTab, "ESP")

local billboardGuis = {}
local espConnections = {}
local espEnabled = false
local selectedColor = "RGB"

MakeDropdown(playerTab, "ESP Color", {"RGB", "White", "Black", "Red", "Green", "Blue", "Yellow", "Pink", "Purple"}, function(value)
    selectedColor = value
end)

local function getESPColor()
    if selectedColor == "RGB" then
        local h = (tick() % 5) / 5
        return Color3.fromHSV(h, 1, 1)
    elseif selectedColor == "Black" then return Color3.fromRGB(0, 0, 0)
    elseif selectedColor == "White" then return Color3.fromRGB(255, 255, 255)
    elseif selectedColor == "Red" then return Color3.fromRGB(255, 0, 0)
    elseif selectedColor == "Green" then return Color3.fromRGB(0, 255, 0)
    elseif selectedColor == "Blue" then return Color3.fromRGB(0, 170, 255)
    elseif selectedColor == "Yellow" then return Color3.fromRGB(255, 255, 0)
    elseif selectedColor == "Pink" then return Color3.fromRGB(255, 105, 180)
    elseif selectedColor == "Purple" then return Color3.fromRGB(128, 0, 128)
    end
    return Color3.new(1, 1, 1)
end

local function updateESP(targetPlayer)
    if targetPlayer == localPlayer then return end
    if not espEnabled then return end

    local character = targetPlayer.Character
    if character then
        local head = character:FindFirstChild("Head")
        if head then
            if billboardGuis[targetPlayer] then
                billboardGuis[targetPlayer]:Destroy()
            end

            local billboard = Instance.new("BillboardGui")
            billboard.Name = "ESP_Billboard"
            billboard.Parent = head
            billboard.Adornee = head
            billboard.Size = UDim2.new(0, 200, 0, 50)
            billboard.StudsOffset = Vector3.new(0, 3, 0)
            billboard.AlwaysOnTop = true

            local textLabel = Instance.new("TextLabel")
            textLabel.Name = "TextLabel"
            textLabel.Parent = billboard
            textLabel.Size = UDim2.new(1, 0, 1, 0)
            textLabel.BackgroundTransparency = 1
            textLabel.TextStrokeTransparency = 0.5
            textLabel.Font = Enum.Font.SourceSansBold
            textLabel.TextSize = 14
            textLabel.Text = targetPlayer.Name .. " | " .. targetPlayer.AccountAge .. " days"
            textLabel.TextColor3 = getESPColor()

            billboardGuis[targetPlayer] = billboard
        end
    end
end

local function removeESP(targetPlayer)
    if billboardGuis[targetPlayer] then
        billboardGuis[targetPlayer]:Destroy()
        billboardGuis[targetPlayer] = nil
    end
end

MakeToggle(playerTab, "Enable ESP", false, function(value)
    espEnabled = value
    if espEnabled then
        for _, plyr in pairs(Players:GetPlayers()) do updateESP(plyr) end

        local updateConnection = RunService.Heartbeat:Connect(function()
            for _, plyr in pairs(Players:GetPlayers()) do updateESP(plyr) end
            if selectedColor == "RGB" then
                for _, plyr in pairs(Players:GetPlayers()) do
                    local gui = billboardGuis[plyr]
                    if gui and gui:FindFirstChild("TextLabel") then
                        gui.TextLabel.TextColor3 = getESPColor()
                    end
                end
            end
        end)
        table.insert(espConnections, updateConnection)

        local playerAdded = Players.PlayerAdded:Connect(function(plyr)
            updateESP(plyr)
            local charConn = plyr.CharacterAdded:Connect(function() updateESP(plyr) end)
            table.insert(espConnections, charConn)
        end)
        table.insert(espConnections, playerAdded)

        local playerRemoving = Players.PlayerRemoving:Connect(function(plyr) removeESP(plyr) end)
        table.insert(espConnections, playerRemoving)
    else
        for _, plyr in pairs(Players:GetPlayers()) do removeESP(plyr) end
        for _, conn in pairs(espConnections) do conn:Disconnect() end
        espConnections = {}
        billboardGuis = {}
    end
end)

