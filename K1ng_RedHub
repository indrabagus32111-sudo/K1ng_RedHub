        end)
    else
        for _, conn in pairs(UltimateNoclip.Connections) do conn:Disconnect() end
        if localPlayer.Character then managePlayerCollisions(localPlayer.Character) end
        for ball in pairs(UltimateNoclip.SoccerBalls) do
