-- Variables to store state for restoration
local savedBodyParts = {}
local activeAnimations = {}

local function restoreBody()
    local humanoid = localPlayer.Character and localPlayer.Character:FindFirstChildOfClass("Humanoid")
    if humanoid and next(savedBodyParts) then
        local restoreArgs = {
            savedBodyParts.Torso,
            savedBodyParts.RightArm,
            savedBodyParts.LeftArm,
            savedBodyParts.RightLeg,
            savedBodyParts.LeftLeg,
            savedBodyParts.Head
        }
        pcall(function()
            ReplicatedStorage.Remotes.ChangeCharacterBody:InvokeServer(restoreArgs)
        end)
        savedBodyParts = {}
    end
end

local function stopAnimations()
    for _, track in pairs(activeAnimations) do
        pcall(function() track:Stop() end)
    end
    activeAnimations = {}
end

MakeToggle(nukeTab, "Nuke Skybox", false, function(value)
    if value then
        local character = localPlayer.Character
        local humanoid = character and character:FindFirstChildOfClass("Humanoid")
        
        if humanoid then
            -- Save current body parts
            local desc = humanoid:GetAppliedDescription()
            savedBodyParts = {
                Torso = desc.Torso, RightArm = desc.RightArm, LeftArm = desc.LeftArm,
                RightLeg = desc.RightLeg, LeftLeg = desc.LeftLeg, Head = desc.Head
            }

            -- Apply Nuke Body
            local args = {123402086843885, 100839513065432, 78300682916056, 86276701020724, 78409653958165, 15093053680}
            ReplicatedStorage.Remotes.ChangeCharacterBody:InvokeServer(args)

            -- Play Animations
            local anim1 = Instance.new("Animation")
            anim1.AnimationId = "rbxassetid://70883871260184"
            local track1 = humanoid:LoadAnimation(anim1)
            track1:Play(0.1, 1, 0.01)
            table.insert(activeAnimations, track1)

            local anim2 = Instance.new("Animation")
            anim2.AnimationId = "rbxassetid://3695333486"
            local track2 = humanoid:LoadAnimation(anim2)
            track2:Play(0.1, 1, 0)
            table.insert(activeAnimations, track2)
        end
    else
        -- Clean up
        stopAnimations()
        restoreBody()
    end
end)
