local function MakeSlider(parent, text, min, max, default, callback)
    local frame = Instance.new("Frame")
    frame.Parent = parent
    frame.Size = UDim2.new(1, 0, 0, 45)
    frame.BackgroundColor3 = Color3.fromRGB(30, 0, 0)
    frame.BackgroundTransparency = 0.5
    Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 6)
    Instance.new("UIStroke", frame).Color = Color3.fromRGB(200, 0, 0)
    
    local titleLbl = Instance.new("TextLabel")
    titleLbl.Parent = frame
    titleLbl.Size = UDim2.new(1, -15, 0.5, 0)
    titleLbl.Position = UDim2.new(0, 10, 0, 2)
    titleLbl.BackgroundTransparency = 1
    titleLbl.Text = text .. " (" .. default .. ")"
    titleLbl.TextColor3 = Color3.fromRGB(255, 255, 255)
    titleLbl.Font = Enum.Font.GothamBold
    titleLbl.TextSize = 13
    titleLbl.TextXAlignment = Enum.TextXAlignment.Left

    local sliderBg = Instance.new("TextButton")
    sliderBg.Parent = frame
    sliderBg.Size = UDim2.new(1, -20, 0, 10)
    sliderBg.Position = UDim2.new(0, 10, 0.6, 0)
    sliderBg.BackgroundColor3 = Color3.fromRGB(15, 0, 0)
    sliderBg.Text = ""
    Instance.new("UICorner", sliderBg).CornerRadius = UDim.new(0, 4)

    local sliderFill = Instance.new("Frame")
    sliderFill.Parent = sliderBg
    sliderFill.Size = UDim2.new((default - min) / (max - min), 0, 1, 0)
    sliderFill.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
    Instance.new("UICorner", sliderFill).CornerRadius = UDim.new(0, 4)

    local function updateSlider(input)
        local pos = math.clamp((input.Position.X - sliderBg.AbsolutePosition.X) / sliderBg.AbsoluteSize.X, 0, 1)
        sliderFill.Size = UDim2.new(pos, 0, 1, 0)
        local value = math.floor(min + (max - min) * pos)
        titleLbl.Text = text .. " (" .. value .. ")"
        pcall(callback, value)
    end

    local dragging = false
    sliderBg.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            updateSlider(input)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            updateSlider(input)
        end
    end)
end

local function MakeDropdown(parent, text, options, callback)
    local dropBtn = Instance.new("TextButton")
    dropBtn.Parent = parent
    dropBtn.Size = UDim2.new(1, 0, 0, 35)
    dropBtn.BackgroundColor3 = Color3.fromRGB(80, 0, 0) 
    dropBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    dropBtn.Text = text .. ": Select"
    dropBtn.Font = Enum.Font.GothamBold
    dropBtn.TextSize = 14
    Instance.new("UICorner", dropBtn).CornerRadius = UDim.new(0, 6)
    Instance.new("UIStroke", dropBtn).Color = Color3.fromRGB(255, 100, 100) 
    
    local dropFrame = Instance.new("Frame")
    dropFrame.Parent = parent
    dropFrame.BackgroundColor3 = Color3.fromRGB(20, 0, 0)
    dropFrame.Visible = false
    Instance.new("UICorner", dropFrame).CornerRadius = UDim.new(0, 6)
    
    local dropLayout = Instance.new("UIListLayout")
    dropLayout.Parent = dropFrame
    dropLayout.SortOrder = Enum.SortOrder.LayoutOrder
    
    local function refreshOptions(newOptions)
        for _, child in ipairs(dropFrame:GetChildren()) do
            if child:IsA("TextButton") then child:Destroy() end
        end
        dropFrame.Size = UDim2.new(1, 0, 0, #newOptions * 30)
        for i, option in ipairs(newOptions) do
            local optBtn = Instance.new("TextButton")
            optBtn.Parent = dropFrame
            optBtn.Size = UDim2.new(1, 0, 0, 30)
            optBtn.BackgroundColor3 = Color3.fromRGB(30, 0, 0)
            optBtn.TextColor3 = Color3.fromRGB(200, 200, 200)
            optBtn.Text = option
            optBtn.Font = Enum.Font.Gotham
            optBtn.TextSize = 13
            
            optBtn.MouseButton1Click:Connect(function()
                dropBtn.Text = text .. ": " .. option
                dropFrame.Visible = false
                pcall(callback, option)
            end)
        end
    end
    
    refreshOptions(options)
    
    dropBtn.MouseButton1Click:Connect(function()
        dropFrame.Visible = not dropFrame.Visible
    end)
    
    return {
        Refresh = refreshOptions,
        Reset = function()
            dropBtn.Text = text .. ": Select"
        end
    }
end

