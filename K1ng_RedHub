local ESPData = {
    espEnabled = false,
    espType = "Name + age",
    selectedColor = "RGB",
    billboardGuis = {},
    highlights = {},
    lines = {},
    connections = {}
}

local function getESPColor()
    local colors = {
        RGB = function()
            local h = (tick() % 5) / 5
            return Color3.fromHSV(h, 1, 1)
        end,
        Black = Color3.fromRGB(0,0,0), White = Color3.fromRGB(255,255,255), Red = Color3.fromRGB(255,0,0), Green = Color3.fromRGB(0,255,0), Blue = Color3.fromRGB(0,170,255), Yellow = Color3.fromRGB(255,255,0), Pink = Color3.fromRGB(255,105,180), Purple = Color3.fromRGB(128,0,128) 
    }
    local c = colors[ESPData.selectedColor]
    if type(c) == "function" then
        return c()
    end
    return c or Color3.new(1,1,1)
end

local function clearAllESP()
    for _, gui in pairs(ESPData.billboardGuis) do
        pcall(function() gui:Destroy() end)
    end
    for _, h in pairs(ESPData.highlights) do
        pcall(function() h:Destroy() end)
    end
    for _, l in pairs(ESPData.lines) do
        pcall(function() l:Remove() end)
    end
    for _, c in pairs(ESPData.connections) do
        pcall(function() c:Disconnect() end)
    end
    
    ESPData.billboardGuis = {}
    ESPData.highlights = {}
    ESPData.lines = {}
    ESPData.connections = {}
end

local function createNameESP(player)
    if player == localPlayer then return end
    if not player.Character or not player.Character:FindFirstChild("Head") then return end
    
    local head = player.Character.Head
    if ESPData.billboardGuis[player] then
        ESPData.billboardGuis[player]:Destroy()
    end
    
    local gui = Instance.new("BillboardGui", head)
    gui.Size = UDim2.new(0, 200, 0, 50)
    gui.StudsOffset = Vector3.new(0, 3, 0)
    gui.AlwaysOnTop = true
    
    local txt = Instance.new("TextLabel", gui)
    txt.Size = UDim2.new(1, 0, 1, 0)
    txt.BackgroundTransparency = 1
    txt.TextStrokeTransparency = 0.5
    txt.Font = Enum.Font.SourceSansBold
    txt.TextSize = 14
    txt.Text = player.Name .. " | " .. player.AccountAge .. " dias"
    txt.TextColor3 = getESPColor()
    
    ESPData.billboardGuis[player] = gui
end

local function createHighlightESP(player)
    if player == localPlayer then return end
    if not player.Character then return end
    
    if ESPData.highlights[player] then
        ESPData.highlights[player]:Destroy()
    end
    
    local h = Instance.new("Highlight", player.Character)
    h.FillColor = getESPColor()
    h.FillTransparency = 0.5
    h.OutlineTransparency = 0
    h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    
    ESPData.highlights[player] = h
end

local function createLineESP(player)
    if player == localPlayer then return end
    
    if ESPData.lines[player] then
        pcall(function() ESPData.lines[player]:Remove() end)
    end
    
    local l = Drawing.new("Line")
    l.Thickness = 2
    l.Transparency = 1
    l.Visible = false
    
    ESPData.lines[player] = l
end

local function applyCurrentESP()
    clearAllESP()
    if not ESPData.espEnabled then return end
    
    for _, p in pairs(Players:GetPlayers()) do
        if ESPData.espType == "Name + age" then
            createNameESP(p)
        elseif ESPData.espType == "Highlight" then
            createHighlightESP(p)
        elseif ESPData.espType == "Lines" then
            createLineESP(p)
        end
    end
    
    table.insert(ESPData.connections, RunService.RenderStepped:Connect(function()
        if not ESPData.espEnabled then return end
        local color = getESPColor()
        
        if ESPData.espType == "Name + age" then
            for _, gui in pairs(ESPData.billboardGuis) do
                if gui:FindFirstChildOfClass("TextLabel") then
                    gui.TextLabel.TextColor3 = color
                end
            end
        elseif ESPData.espType == "Highlight" then
            for _, h in pairs(ESPData.highlights) do
                h.FillColor = color
            end
        elseif ESPData.espType == "Lines" then
            for p, l in pairs(ESPData.lines) do
                if p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                    local pos, on = Camera:WorldToViewportPoint(p.Character.HumanoidRootPart.Position)
                    l.Visible = on
                    if on then
                        l.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
                        l.To = Vector2.new(pos.X, pos.Y)
                        l.Color = color
                    end
                else
                    l.Visible = false
                end
            end
        end
    end))
    
    table.insert(ESPData.connections, Players.PlayerAdded:Connect(function(plyr)
        plyr.CharacterAdded:Connect(function()
            task.wait(1)
            if ESPData.espEnabled then applyCurrentESP() end
        end)
    end))
end

